{
  "name": "shield",
  "version": "1.0.0",
  "description": "Social engineering shield — protects against scams, manipulation, and phishing",
  "author": "Threshold Interactive Studios",
  "main": "main.js",
  "scripts": {
    "start": "electron . --no-sandbox",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.thresholdinteractivestudios.shield",
    "productName": "Shield",
    "copyright": "Copyright © 2026 Threshold Interactive Studios",
    "directories": { "output": "dist" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shield"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
